{
  "manifest_version": 3,
  "name": "DotVault - Secure Env Manager",
  "version": "1.0.0",
  "description": "Securely fill environment variables into Vercel, Netlify, GitHub, AWS, and more",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*.vercel.com/*",
    "https://*.netlify.com/*",
    "https://github.com/*",
    "https://*.github.com/*",
    "https://*.aws.amazon.com/*",
    "https://*.railway.app/*",
    "https://*.render.com/*",
    "https://*.heroku.com/*",
    "https://*.digitalocean.com/*",
    "https://*.cloudflare.com/*",
    "https://*.supabase.com/*",
    "https://*.neon.tech/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vercel.com/*",
        "https://*.netlify.com/*",
        "https://github.com/*",
        "https://*.github.com/*",
        "https://*.aws.amazon.com/*",
        "https://*.railway.app/*",
        "https://*.render.com/*",
        "https://*.heroku.com/*",
        "https://*.digitalocean.com/*",
        "https://*.cloudflare.com/*",
        "https://*.supabase.com/*",
        "https://*.neon.tech/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
