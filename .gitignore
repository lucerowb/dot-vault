# See https://help.github.com/articles/ignoring-files/

# dependencies
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# nested package managers (monorepo uses root pnpm-lock.yaml)
packages/**/package-lock.json
packages/**/node_modules/.package-lock.json

# build outputs
dist/
**/dist/
/build
/.next/
/out/

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# commandcode
.commandcode
