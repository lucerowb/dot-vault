# =============================================================================
# DotVault Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# =============================================================================
# REQUIRED - Core Application
# =============================================================================

# PostgreSQL Database URL
# Local: postgresql://postgres:password@localhost:5432/dotvault
# Production: Use your managed DB (Supabase, Railway, AWS RDS, etc.)
# Add ?sslmode=require for production
DATABASE_URL=

# Better Auth - Secret for signing sessions
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Encryption key for secrets at rest (AES-256-GCM)
# Generate: openssl rand -base64 32
# ⚠️  CRITICAL: Back this up! If lost, all encrypted data is unrecoverable
STORAGE_ENCRYPTION_KEY=

# =============================================================================
# REQUIRED - URLs
# =============================================================================

# Your application's public URL
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth canonical URL (usually same as NEXT_PUBLIC_APP_URL)
# Used for cookies and auth callbacks
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# OPTIONAL - Redis (for rate limiting & quick share)
# =============================================================================

# Upstash Redis REST URL (free tier at upstash.com)
# Required for: ephemeral quick share links, rate limiting
# Without this: uses in-memory fallback (resets on restart)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternative: Self-hosted Redis
# REDIS_URL=redis://localhost:6379

# =============================================================================
# OPTIONAL - Email (required for password resets & invitations)
# =============================================================================

# Option 1: SendGrid (Recommended for production)
# Get from: sendgrid.com → Settings → API Keys
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx

# Option 2: Gmail
# Get from: Google Account → Security → 2-Step Verification → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Option 3: Ethereal (For testing only - emails go to fake inbox)
# Get from: ethereal.email
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=xxxx@ethereal.email
# SMTP_PASS=xxxx

# Sender email address
SMTP_FROM=noreply@localhost

# =============================================================================
# OPTIONAL - OAuth Providers (for social login)
# =============================================================================

# GitHub OAuth
# Get from: GitHub → Settings → Developer settings → OAuth Apps → New
# Homepage URL: http://localhost:3000 (or your domain)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (for repo integrations)
# Get from: GitHub → Settings → Developer settings → GitHub Apps → New
# Slug is in the app’s public URL: https://github.com/apps/<slug>
GITHUB_APP_ID=
GITHUB_APP_SLUG=dot-vault
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=

# Google OAuth
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# OPTIONAL - Security & Networking
# =============================================================================

# Trusted proxy depth for IP parsing
# 1 = Single proxy (Coolify, Traefik, Nginx)
# 0 = No proxy (local dev)
TRUSTED_PROXY_DEPTH=1

# IP Allowlist for admin access (comma-separated CIDR blocks)
# Example: ADMIN_IP_ALLOWLIST=203.0.113.0/24,198.51.100.50
ADMIN_IP_ALLOWLIST=

# =============================================================================
# OPTIONAL - Monitoring & Error Tracking
# =============================================================================

# Sentry DSN for error tracking
# Get from: sentry.io → Projects → Settings → Client Keys
SENTRY_DSN=

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# PRODUCTION - Deployment Specific
# =============================================================================

# Node environment
# NODE_ENV=production

# SSL Certificate paths (if using custom certificates)
# SSL_CERT=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# =============================================================================
# FEATURE FLAGS (optional)
# =============================================================================

# Enable/disable specific features
# ENABLE_REGISTRATION=true
# ENABLE_GUEST_ACCESS=false
# REQUIRE_2FA=false

# =============================================================================
# QUICK START GUIDE
# =============================================================================

# 1. Copy this file:
#    cp .env.example .env.local
#
# 2. Generate required secrets:
#    openssl rand -base64 32  # For BETTER_AUTH_SECRET
#    openssl rand -base64 32  # For STORAGE_ENCRYPTION_KEY
#
# 3. Set up PostgreSQL locally or use a managed service
#
# 4. For email testing, use Ethereal (ethereal.email) - it's free
#
# 5. For production, use SendGrid or AWS SES for reliable email delivery
#
# 6. For OAuth, create GitHub/Google apps (optional but recommended for UX)
#
# 7. For Redis, create a free Upstash database (optional but recommended)
#
# 8. Run migrations:
#    npm run db:migrate
#
# 9. Start the app:
#    npm run dev
