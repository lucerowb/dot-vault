# Upstash Redis (REST) — required for ephemeral “quick share” API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase Postgres (Settings → Database → URI). Use ?sslmode=require
DATABASE_URL=

# Better Auth — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Canonical URL for Better Auth cookies / callbacks (usually same as public app URL)
BETTER_AUTH_URL=http://localhost:3000

# Public site URL (share links, auth client fallback)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption for cloud-stored env blobs (AES-256-GCM at rest): `openssl rand -base64 32`
STORAGE_ENCRYPTION_KEY=
